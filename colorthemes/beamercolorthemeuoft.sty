% Unofficial UofT color theme for the gemini poster theme.
% Modeled on the UMich color theme shipped with gemini.

% ====================
% Definitions
% ====================

\definecolor{UofTBlue}{RGB}{0, 42, 92}        % #002A5C primary
\definecolor{UofTLightBlue}{RGB}{0, 122, 201} % #007AC9 accent
\definecolor{UofTWhite}{RGB}{255, 255, 255}
\definecolor{UofTGray}{RGB}{235, 235, 235}
\definecolor{UofTLightAccent}{RGB}{223, 235, 248}

% ====================
% Theme
% ====================

% Basic colors
\setbeamercolor{palette primary}{fg=UofTBlue,bg=UofTWhite}
\setbeamercolor{palette secondary}{fg=UofTBlue,bg=UofTWhite}
\setbeamercolor{palette tertiary}{bg=UofTBlue,fg=UofTWhite}
\setbeamercolor{palette quaternary}{fg=UofTBlue,bg=UofTWhite}
\setbeamercolor{structure}{fg=UofTBlue}

% Headline
\setbeamercolor{headline}{fg=UofTGray,bg=UofTBlue}
\setbeamercolor{headline rule}{bg=UofTLightBlue}

% Block
\setbeamercolor{block title}{fg=UofTBlue,bg=UofTWhite}
\setbeamercolor{block separator}{bg=UofTBlue}
\setbeamercolor{block body}{fg=UofTBlue,bg=UofTWhite}

% Alert Block
\setbeamercolor{block title alerted}{fg=UofTBlue,bg=UofTLightAccent}
\setbeamercolor{block separator alerted}{bg=UofTBlue}
\setbeamercolor{block body alerted}{fg=UofTBlue,bg=UofTLightAccent}

% Example Block
\setbeamercolor{block title example}{fg=UofTBlue,bg=UofTWhite}
\setbeamercolor{block separator example}{bg=UofTBlue}
\setbeamercolor{block body example}{fg=UofTBlue,bg=UofTWhite}

% Heading
\setbeamercolor{heading}{fg=UofTBlue}

% Itemize
\setbeamercolor{item}{fg=UofTBlue}

% Bibliography
\setbeamercolor{bibliography item}{fg=UofTBlue}
\setbeamercolor{bibliography entry author}{fg=UofTBlue}
\setbeamercolor{bibliography entry title}{fg=UofTBlue}
\setbeamercolor{bibliography entry location}{fg=UofTBlue}
\setbeamercolor{bibliography entry note}{fg=UofTBlue}
